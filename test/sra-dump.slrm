#!/bin/sh
#SBATCH --signal=USR2
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=15
#SBATCH --mem=60G
#SBATCH --time=720:00:00
#SBATCH --output=/home/%u/tmp/errout/sh.job.%j

module load R/4.1.0

sra_dir="/home/liuc9/scratch/mitochondrial/testdata/4_old_donor_MM"




fasterq-dump ${sra_dir}/MM068/SRR17022244.sra --include-technical --mem 50G --threads 20 --split-files --outdir ${sra_dir}/MM0678

fasterq-dump  ${sra_dir}/MM188/SRR17022252.sra --include-technical --mem 50G --threads 20 --split-files --outdir  ${sra_dir}/MM188



mv SRR17022244_1.fastq SRR17022244_S1_L001_I1_001.fastq
mv SRR17022244_2.fastq SRR17022244_S1_L001_R1_001.fastq
mv SRR17022244_3.fastq SRR17022244_S1_L001_R2_001.fastq

mv SRR17022252_1.fastq SRR17022252_S1_L001_I1_001.fastq
mv SRR17022252_2.fastq SRR17022252_S1_L001_R1_001.fastq
mv SRR17022252_3.fastq SRR17022252_S1_L001_R2_001.fastq

